{
  "name": "agent-bench",
  "version": "0.3.0",
  "description": "CLI and full-stack workbench for benchmarking AI agents",
  "packageManager": "pnpm@10.27.0",
  "main": "dist/src/index.js",
  "bin": {
    "agent-bench": "dist/src/index.js"
  },
  "scripts": {
    "build": "pnpm run build:app && pnpm run build:cli",
    "build:app": "next build --webpack",
    "build:cli": "tsc -p tsconfig.cli.json",
    "dev": "next dev",
    "prepare": "pnpm run build:cli",
    "test": "pnpm run build:cli && node scripts/run-node-tests.cjs",
    "test:e2e": "playwright test",
    "start": "node dist/src/index.js",
    "ui": "next dev --port 4173"
  },
  "keywords": [
    "benchmark",
    "agents",
    "cli",
    "sqlite"
  ],
  "license": "MIT",
  "dependencies": {
    "ai": "^5.0.146",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "dotenv": "^17.3.1",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.58.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp"
    ]
  }
}
