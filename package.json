{
  "name": "agent-bench",
  "version": "0.1.0",
  "description": "CLI and web dashboard for benchmarking AI agents",
  "type": "commonjs",
  "main": "dist/src/index.js",
  "bin": {
    "agent-bench": "dist/src/index.js"
  },
  "scripts": {
    "build": "npm run build:css && tsc -p tsconfig.json",
    "build:css": "tailwindcss -i src/ui/styles/input.css -o src/ui/public/styles.css --minify",
    "dev": "tsc -w -p tsconfig.json",
    "prepare": "npm run build",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "start": "node dist/src/index.js",
    "ui": "node dist/src/index.js ui"
  },
  "keywords": [
    "benchmark",
    "agents",
    "cli",
    "sqlite"
  ],
  "license": "MIT",
  "dependencies": {
    "ai": "^5.0.146",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
